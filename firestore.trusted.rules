rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function profile() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; }
    function role() { return profile().role; }
    function isActiveUser() { return signedIn() && (!('is_active' in profile()) || profile().is_active == true); }
    function isMedicalUser() { return isActiveUser() && role() in ['PERAWAT', 'SUPERVISOR', 'DOKTER', 'ADMIN', 'PK_II', 'PK_III']; }
    function isSupervisor() { return isActiveUser() && role() in ['SUPERVISOR', 'PK_III']; }
    function isAdmin() { return isActiveUser() && role() == 'ADMIN'; }
    function validUserText(value, min, max) {
      return value is string && value.size() >= min && value.size() <= max;
    }
    function validSelfUserUpdate(userId, next, previous) {
      return signedIn() && request.auth.uid == userId && isActiveUser()
        && next.diff(previous).affectedKeys().hasOnly(['displayName', 'email', 'username', 'unit', 'updated_at'])
        && next.role == previous.role
        && next.get('is_active', true) == previous.get('is_active', true)
        && validUserText(next.displayName, 1, 120)
        && validUserText(next.email, 0, 160)
        && next.get('username', '') is string
        && next.get('username', '').size() <= 80
        && validUserText(next.unit, 1, 120)
        && next.updated_at == request.time;
    }
    function validPatient(data) {
      return data.rm is string && data.rm.size() > 0
        && data.nama is string && data.nama.size() > 0
        && data.tanggal_lahir is string
        && data.jenis_kelamin in ['L', 'P']
        && data.bb_kering is number && data.bb_kering >= 20 && data.bb_kering <= 250;
    }

    match /users/{userId} {
      allow read: if signedIn() && (request.auth.uid == userId || isAdmin());
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || validSelfUserUpdate(userId, request.resource.data, resource.data);
    }
    match /patient_keys/{rmKey} {
      allow read, create, update, delete: if isSupervisor() || isAdmin();
    }
    match /patients/{patientId} {
      allow read: if isMedicalUser();
      allow create: if (isSupervisor() || isAdmin()) && validPatient(request.resource.data);
      allow update: if (isSupervisor() || isAdmin()) && validPatient(request.resource.data)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'rm', 'nama', 'tanggal_lahir', 'jenis_kelamin', 'bb_kering', 'notes',
          'is_active', 'current_dry_weight_version', 'updated_at'
        ]);
      allow delete: if isAdmin();
      match /sessions/{sessionId} {
        allow read: if isMedicalUser();
        allow create, update, delete: if false;
      }
    }
    match /alerts/{alertId} {
      allow read: if isMedicalUser();
      allow create: if false;
      allow update: if (isSupervisor() || role() == 'DOKTER' || isAdmin())
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'acknowledged', 'acknowledged_by', 'acknowledged_at'
        ]);
      allow delete: if isAdmin();
    }
    match /audit_logs/{auditId} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }
    match /{document=**} { allow read, write: if false; }
  }
}
